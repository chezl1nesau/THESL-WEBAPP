NODE_ENV=development
PORT=3000

# Required JWT secrets (use long random values in real environments)
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_RESET_SECRET=replace-with-long-random-reset-secret

# Comma-separated list of allowed frontend origins
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# Optional frontend URL used in password reset emails
FRONTEND_URL=http://localhost:5173

# SMTP settings (required for forgot-password email delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-smtp-username
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=no-reply@example.com
